{
  "manifest_version": 3,
  "name": "Better DeepSeek",
  "description": "Add local folder management to DeepSeek web.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://chat.deepseek.com/*", "https://www.deepseek.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
