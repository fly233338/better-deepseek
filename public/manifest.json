{
  "manifest_version": 3,
  "name": "Better DeepSeek",
  "description": "DeepSeek 侧边栏文件夹管理 + 提示词库，支持导入导出与外部来源浏览。",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://www.deepseek.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
