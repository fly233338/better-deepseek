{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Better DeepSeek Prompt Index",
  "description": "Schema for the prompt library data file consumed by the Better DeepSeek browser extension.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["title", "content", "tags", "fingerprint"],
    "properties": {
      "title": { "type": "string", "minLength": 1 },
      "description": { "type": "string" },
      "content": { "type": "string", "minLength": 1 },
      "tags": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1
      },
      "category": { "type": "string" },
      "version": { "type": "integer", "minimum": 1 },
      "updatedAt": { "type": "string", "format": "date" },
      "fingerprint": { "type": "string", "minLength": 1 }
    }
  }
}
